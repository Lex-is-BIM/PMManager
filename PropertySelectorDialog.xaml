<Window x:Class="PMManager.PropertySelectorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PMManager"
        mc:Ignorable="d"
        Title="Выбор свойств" 
        Height="640" 
        Width="1300"
        WindowStartupLocation="CenterOwner"
        Background="#FFE7EBEE">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Renga.WPF.Styles;component/Themes/Renga.Implicit.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <local:ArrayToStringConverter x:Key="ArrayToStringConverter"/>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DataGrid x:Name="PropertiesData"
            SelectionChanged="PropertiesData_SelectionChanged"
            Grid.Row="0"
            AutoGenerateColumns="False"
            SelectionMode="Single"
            CanUserAddRows="False"
            HeadersVisibility="Column"
            Margin="0,0,0,10"
            ItemsSource="{Binding}"
            GridLinesVisibility="None"
            Loaded="PropertiesData_Loaded" 
            Sorting="PropertiesData_Sorting">

            <!-- Ресурсы контекстного меню -->
            <DataGrid.Resources>
                <ContextMenu x:Key="RowContextMenu">
                    <MenuItem Header="Установить" Click="SetChecked_Click"/>
                    <MenuItem Header="Снять" Click="UncheckChecked_Click"/>
                    <Separator/>
                    <MenuItem Header="Установить все" Click="CheckAll_Click"/>
                    <MenuItem Header="Снять все" Click="UncheckAll_Click"/>
                </ContextMenu>

                <!-- Восстановление стилей выделения -->
                <Style TargetType="DataGridCell">
                    <Setter Property="BorderBrush" Value="#FFA9B4BE"/>
                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                    <Setter Property="Padding" Value="4"/>
                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                    <Style.Resources>
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#FFCBD2D8"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="Black"/>
                    </Style.Resources>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="BorderBrush" Value="#FFA9B4BE"/>
                            <Setter Property="Background" Value="#FFCBD2D8"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.Resources>

            <!-- Стиль строк для подсветки -->
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Height" Value="25"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#FFE7EBEE"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>

            <!-- Колонки -->
            <DataGrid.Columns>
                <!-- Колонка с чекбоксом -->
                <DataGridTemplateColumn Header="Имя" Width="240" SortMemberPath="Name" CanUserSort="True" SortDirection="Ascending">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                            ContextMenu="{StaticResource RowContextMenu}">
                                <CheckBox VerticalAlignment="Center"
                              Margin="5,0,0,0"
                              IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center"
                              Margin="0,0,0,0"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Текстовые колонки с отступом -->
                <DataGridTextColumn Header="Тип данных" Binding="{Binding Type}" Width="140">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Margin" Value="3,0,0,0"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Уникальный идентификатор" Binding="{Binding Guid}" Width="250">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Margin" Value="3,0,0,0"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Колонка с переносом текста -->
                <DataGridTemplateColumn Header="Типы объектов использующие свойство" Width="Auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding ObjectTypes, 
                          Converter={StaticResource ArrayToStringConverter}}"
                          TextWrapping="Wrap"
                          Margin="3,0,0,0"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Кнопки -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Width="80" Margin="0,0,10,0" Click="ButtonOk_Click"/>
            <Button Content="Отмена" Width="80" Click="ButtonCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>